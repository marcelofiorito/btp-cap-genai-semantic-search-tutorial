# ---------- DMS (real) ----------
# Se deixar DMS_BASE_URL vazio, o app roda em modo mock.
DMS_BASE_URL=
DMS_REPOSITORY_ID=

# Opção 1: token pronto (mais simples para teste rápido)
DMS_BEARER_TOKEN=

# Opção 2: OAuth client credentials
DMS_CLIENT_ID=
DMS_CLIENT_SECRET=
DMS_TOKEN_URL=

# ---------- Grounding / embeddings ----------
# false = embedding determinístico local (sem AI Core)
# true  = usa @sap-ai-sdk/foundation-models (instalar dependência)
GROUNDING_USE_AICORE=false
GROUNDING_EMBEDDING_MODEL=text-embedding-3-small
GROUNDING_AI_RESOURCE_GROUP=default
GROUNDING_MAX_TEXT_LENGTH=20000
