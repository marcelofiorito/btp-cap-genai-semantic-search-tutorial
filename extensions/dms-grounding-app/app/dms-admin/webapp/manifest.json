{
  "_version": "1.28.0",
  "sap.app": {
    "id": "dms.grounding.admin",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/grounding/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.132.0",
      "libs": {
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "dms.grounding.admin.i18n.i18n"
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": "",
          "name": "SourceDocumentsList",
          "target": "SourceDocumentsList"
        },
        {
          "pattern": "SourceDocuments:?query:",
          "name": "SourceDocumentsListByPath",
          "target": "SourceDocumentsList"
        },
        {
          "pattern": "SourceDocuments({key}):?query:",
          "name": "SourceDocumentsObjectPage",
          "target": "SourceDocumentsObjectPage"
        },
        {
          "pattern": "SyncRuns:?query:",
          "name": "SyncRunsList",
          "target": "SyncRunsList"
        },
        {
          "pattern": "DocumentChunks:?query:",
          "name": "DocumentChunksList",
          "target": "DocumentChunksList"
        }
      ],
      "targets": {
        "SourceDocumentsList": {
          "type": "Component",
          "id": "SourceDocumentsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "SourceDocuments",
              "liveMode": true,
              "variantManagement": "Page",
              "navigation": {
                "SourceDocuments": {
                  "detail": {
                    "route": "SourceDocumentsObjectPage"
                  }
                }
              }
            }
          }
        },
        "SourceDocumentsObjectPage": {
          "type": "Component",
          "id": "SourceDocumentsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "SourceDocuments"
            }
          }
        },
        "SyncRunsList": {
          "type": "Component",
          "id": "SyncRunsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "SyncRuns",
              "liveMode": true,
              "variantManagement": "Page"
            }
          }
        },
        "DocumentChunksList": {
          "type": "Component",
          "id": "DocumentChunksList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "DocumentChunks",
              "liveMode": true,
              "variantManagement": "Page"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
